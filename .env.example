# Application Settings
APP_NAME="Autonomous Pothole Intelligence System"
APP_VERSION="1.0.0"
DEBUG=false

# Database (PostgreSQL)
DATABASE_URL=postgresql://pothole_user:pothole_pass@localhost:5432/pothole_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ML Model
MODEL_PATH=ml/models/yolov8_pothole.pt
MODEL_CONFIDENCE=0.5
MODEL_IOU=0.45

# Storage
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760  # 10 MB

# Government Portal (mock)
PG_PORTAL_URL=https://pgportal.gov.in/api
PG_PORTAL_API_KEY=your_api_key_here

# Weather API (OpenWeatherMap)
WEATHER_API_KEY=your_openweather_key_here
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# Escalation Timeouts (days)
FIRST_ESCALATION_DAYS=7
SECOND_ESCALATION_DAYS=14
PUBLIC_FLAG_DAYS=30

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
